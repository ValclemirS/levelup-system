# ===== Servidor =====
PORT=5000
NODE_ENV=development

# ===== Supabase =====
# Em Project Settings → API no painel do Supabase:
#   SUPABASE_URL              = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" (secreta — só no backend!)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_a_service_role_key_aqui

# ===== Autenticação JWT =====
# Gere um segredo forte (mín. 32 chars) e NUNCA versione o .env real:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_este_segredo_por_uma_string_longa_e_aleatoria
JWT_EXPIRES_IN=30d

# ===== CORS =====
# Apps mobile nativos (Flutter) não enviam Origin, então não precisam constar.
CORS_ORIGIN=http://localhost:5173,http://localhost,capacitor://localhost

# ===== Vercel Cron =====
# Protege os endpoints /api/cron/*. Defina nas variáveis da Vercel.
# CRON_SECRET=string_aleatoria_longa
