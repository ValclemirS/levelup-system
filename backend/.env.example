# ===== Servidor =====
PORT=5000
NODE_ENV=development

# ===== Banco de dados MongoDB =====
# Local:
MONGODB_URI=mongodb://localhost:27017/
# MongoDB Atlas (nuvem) - substitua usuario, senha e cluster:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/levelup_system?retryWrites=true&w=majority

# ===== Autenticação JWT =====
# Gere um segredo forte (mín. 32 chars) e NUNCA versione o .env real:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Na Vercel, defina JWT_SECRET nas Environment Variables do projeto.
JWT_SECRET=troque_este_segredo_por_uma_string_longa_e_aleatoria
JWT_EXPIRES_IN=30d

# ===== CORS (origem do frontend) =====
# Vite roda em 5173. Capacitor usa capacitor://localhost e http://localhost
# Apps mobile nativos (Flutter) não enviam Origin, então não precisam constar aqui.
CORS_ORIGIN=http://localhost:5173,http://localhost,capacitor://localhost

# ===== Vercel Cron =====
# Protege os endpoints /api/cron/*. Na Vercel, defina CRON_SECRET nas
# variáveis de ambiente do projeto — ela envia "Authorization: Bearer <valor>".
# CRON_SECRET=string_aleatoria_longa
